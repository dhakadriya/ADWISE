# Environment Variables for Production

# Secret key for JWT tokens (CHANGE THIS!)
SECRET_KEY=your-super-secret-key-here-change-me

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-app.netlify.app,https://your-domain.com

# Database URL (when you add a database)
# DATABASE_URL=postgresql://user:password@host:port/database

# API Configuration
API_TITLE=Adwise Marketing System API
API_VERSION=1.0.0

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
